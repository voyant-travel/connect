{
  "name": "@voyant-travel/connect-adapter",
  "version": "0.4.0",
  "description": "Voyant Connect catalog SourceAdapter for Voyant apps.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/voyant-travel/connect.git",
    "directory": "packages/connect-adapter"
  },
  "homepage": "https://github.com/voyant-travel/connect#readme",
  "bugs": {
    "url": "https://github.com/voyant-travel/connect/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "sideEffects": false,
  "keywords": [
    "voyant",
    "voyant-connect",
    "catalog",
    "adapter",
    "sdk",
    "typescript"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src --max-warnings 0",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@voyant-travel/connect-sdk": "workspace:*"
  },
  "peerDependencies": {
    "@voyant-travel/catalog": ">=0.130.0 <1"
  },
  "devDependencies": {
    "@voyant-sdk/eslint-config": "workspace:*",
    "@voyant-sdk/typescript-config": "workspace:*",
    "@voyant-travel/catalog": "^0.130.0",
    "eslint": "^9.39.1",
    "typescript": "5.9.2"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  }
}
